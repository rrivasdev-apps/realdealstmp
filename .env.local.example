# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: bypasses Row Level Security. Only use in trusted server code
# (never expose to the client, never prefix with NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: used by backend routes that call the Anthropic API directly.
ANTHROPIC_API_KEY=
